rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: articles
    // Fields:
    //   - title: string (required, 1-200 chars)
    //   - category: string (required, 1-50 chars)
    //   - image: string (optional, URL)
    //   - excerpt: string (optional, 1-500 chars)
    //   - content: string (required, 1-50000 chars)
    //   - date: string (required)
    //   - createdAt: number (required, immutable)
    //   - updatedAt: number (required)
    //   - authorId: string (required, immutable, matches auth.uid)
    //
    // Collection: settings
    // Document ID: main
    // Fields:
    //   - heroSubtitle: string
    //   - heroTitle: string
    //   - heroImage: string
    //   - heroDesc: string
    //   - aboutDesc: string
    //   - botDesc: string
    //   - updatedAt: number
    //
    // Collection: users
    // Fields:
    //   - email: string (required)
    //   - role: string (required, ['admin', 'user'])
    //   - uid: string (required, immutable)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "wmitrawan@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidUrl(url) {
      return url is string && (url.matches("^https://.*") || url.matches("^http://.*"));
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================

    function isValidArticle(data) {
      return data.title is string && data.title.size() > 0 && data.title.size() <= 200 &&
             data.category is string && data.category.size() > 0 && data.category.size() <= 50 &&
             (!('image' in data) || isValidUrl(data.image)) &&
             (!('excerpt' in data) || (data.excerpt is string && data.excerpt.size() <= 500)) &&
             data.content is string && data.content.size() > 0 && data.content.size() <= 50000 &&
             data.date is string &&
             data.createdAt is number &&
             data.updatedAt is number &&
             data.authorId is string && data.authorId == request.auth.uid;
    }

    function isValidSettings(data) {
      return (!('heroSubtitle' in data) || data.heroSubtitle is string) &&
             (!('heroTitle' in data) || data.heroTitle is string) &&
             (!('heroImage' in data) || isValidUrl(data.image)) &&
             (!('heroDesc' in data) || data.heroDesc is string) &&
             (!('aboutDesc' in data) || data.aboutDesc is string) &&
             (!('botDesc' in data) || data.botDesc is string) &&
             data.updatedAt is number;
    }

    function isValidUser(data) {
      return data.email is string &&
             data.role in ['admin', 'user'] &&
             data.uid is string && data.uid == request.auth.uid;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /articles/{articleId} {
      allow read: if true; // Publicly readable
      allow create: if isAuthenticated() && isValidArticle(request.resource.data);
      allow update: if isAuthenticated() && 
                      isValidArticle(request.resource.data) && 
                      request.resource.data.authorId == resource.data.authorId &&
                      request.resource.data.createdAt == resource.data.createdAt &&
                      (request.auth.uid == resource.data.authorId || isAdmin());
      allow delete: if isAuthenticated() && (request.auth.uid == resource.data.authorId || isAdmin());
    }

    match /settings/main {
      allow read: if true;
      allow write: if isAdmin() && isValidSettings(request.resource.data);
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && isValidUser(request.resource.data) && request.resource.data.role == 'user';
      allow update: if isOwner(userId) && 
                      isValidUser(request.resource.data) && 
                      request.resource.data.role == resource.data.role && // Cannot change own role
                      isAdmin() == false; // Admin check for self-update is redundant but safe
      allow write: if isAdmin() && isValidUser(request.resource.data);
    }

    match /test/connection {
      allow read: if true;
    }
    
    match /{path=**} {
      allow read, write: if false;
    }
  }
}
